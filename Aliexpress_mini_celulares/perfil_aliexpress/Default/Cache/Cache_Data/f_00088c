    /* CSS Custom Properties - Typography Patterns */
    :root {
        /* Typography Patterns */
        --font-family-primary: 'Roboto', sans-serif;
        --font-family-system: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;

        /* Titulo */
        --title-font-family: var(--font-family-primary);
        --title-font-weight: 500;
        --title-font-style: normal;
        --title-font-size-xs: 18px;
        /* 320px+ */
        --title-font-size-sm: 20px;
        /* 481px+ */
        --title-font-size-md: 24px;
        /* 769px+ */
        --title-font-size-lg: 28px;
        /* 1025px+ */
        --title-font-size-xl: 32px;
        /* 1441px+ */
        --title-line-height: 1.25;
        --title-letter-spacing: 0%;
        --title-vertical-align: middle;

        /* Texto Normal */
        --text-font-size-xxs: 10px;
        /* Extra small */
        --text-font-size-xs: 12px;
        /* 320px+ */
        --text-font-size-sm: 16px;
        /* 481px+ */
        --text-font-size-md: 18px;
        /* 769px+ */
        --text-font-size-lg: 20px;
        /* 1025px+ */
        --text-font-size-xl: 22px;
        /* 1441px+ */
        --text-line-height: 1.5;

        /* Texto  */
        --text-width: 649px;
        --text-height: 120px;
        --text-opacity: 1;
        --text-gap: 10px;
        --text-top: 56px;
        --text-left: -1.53px;

        /* Cores */
        --color-primary: #00203E;
        --color-secondary: #002B52;
        --color-accent: #4A90E2;
        --color-accent-light: #87CEEB;
        --color-accent-blue: #339eff;
        --color-bright-blue: #339EFF;
        --color-bright-blue-alpha: #339EFFB5;
        --color-dark-blue: #013361;
        --color-xray-bg: #06549C;
        --color-text-primary: #333;
        --color-text-white: #fff;
        --color-text-light: #a6d96a;
        --color-text-blue: #0086FF;

        /* Espaçamento */
        --spacing-xs: 12px;
        --spacing-sm: 16px;
        --spacing-md: 22px;
        --spacing-lg: 24px;
        --spacing-xl: 26px;
        --spacing-2xl: 28px;
        --spacing-3xl: 32px;
        --spacing-4xl: 40px;
        --spacing-5xl: 48px;
        --spacing-6xl: 56px;
        --spacing-7xl: 60px;
        --spacing-8xl: 80px;
        --spacing-9xl: 100px;

        /* Bordas*/
        --radius-xs: 4px;
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 50%;

        /* Sombras */
        --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.3);
        --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.3);
        --text-shadow-sm: 1px 1px 2px rgba(0, 0, 0, 0.5);
        --text-shadow-md: 2px 2px 4px rgba(0, 0, 0, 0.5);

        /* Alturas de linha */
        --line-height-tight: 1.2;
        --line-height-normal: 1.4;
        --line-height-relaxed: 1.5;
        --line-height-loose: 1.6;

        /* Z-Index Variables */
        --z-index-base: 1;
    }

    /* Reset styles */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: var(--font-family-system);
        line-height: var(--line-height-loose);
        color: var(--color-text-primary);
        background-color: var(--color-primary);
    }

    /* Tipografia */
    .title {
        font-family: var(--title-font-family);
        font-weight: var(--title-font-weight);
        font-style: var(--title-font-style);
        font-size: var(--title-font-size-xs);
        line-height: var(--title-line-height);
        letter-spacing: var(--title-letter-spacing);
        vertical-align: var(--title-vertical-align);
        color: var(--color-text-white);
        text-shadow: var(--text-shadow-md);
    }

    .text-normal {
        font-size: var(--text-font-size-xs);
        line-height: var(--text-line-height);
        color: var(--color-text-white);
    }

    .text-underline {
        font-weight: 400;
        font-style: normal;
        font-size: 14px;
        line-height: 25.6px;
        letter-spacing: 0%;
        vertical-align: middle;
        text-decoration: underline;
        text-decoration-style: solid;
        text-decoration-thickness: 1px;
    }


    /* Header */
    .header {
        width: 100%;
        background-image: url('images/banner-header.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        max-height: 120px;
        padding: var(--spacing-xl) var(--spacing-md);
        position: relative;
    }

    .header__content {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: var(--color-text-white);
        max-width: 100%;
        width: 100%;
    }

    .header__title {
        text-align: center;
        margin: 0 var(--spacing-xs);
    }

    .header__subtitle {
        text-align: center;
        opacity: 0.9;
        text-shadow: var(--text-shadow-sm);
        margin: 0 var(--spacing-xs);
    }

    .header__logo {
        height: var(--spacing-xl);
        width: auto;
        margin: 0 var(--spacing-xs);
    }

    /* Seção - Papo Rápido */
    .video-section {
        padding: var(--spacing-4xl) var(--spacing-md);
        background-color: var(--color-primary);
    }

    .video-section__title {
        text-align: left;
        margin-bottom: var(--spacing-2xl);
    }

    .video-section__container {
        position: relative;
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .video-section__wrapper {
        position: relative;
        width: 100%;
        height: 0;
        padding-bottom: 56.25%;
    }

    .video-section__wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    /* Seção - Resumo do Especialista */
    .specialist-resume {
        background-color: var(--color-secondary);
        padding: var(--spacing-4xl) var(--spacing-md);
        min-height: 400px;
    }

    .specialist-resume__content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--spacing-4xl);
    }

    .specialist-resume__summary {
        color: var(--color-text-white);
    }

    .specialist-resume__points {
        color: var(--color-text-white);
        border: 1px solid var(--color-accent);
        border-radius: var(--radius-sm);
        padding: var(--spacing-xl);
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-md);
        flex-wrap: wrap;
    }

    .specialist-resume__title {
        margin-bottom: var(--spacing-lg);
    }

    .specialist-resume__summary-title {
        margin-bottom: var(--spacing-lg);
    }

    .specialist-resume__points-title {
        margin-bottom: var(--spacing-lg);
        text-align: left;
    }

    .specialist-resume__quote {
        font-size: 48px;
        color: var(--color-accent);
        font-weight: bold;
        margin-bottom: var(--spacing-md);
        line-height: 1;
        display: flex;
        gap: var(--spacing-md);
    }

    .specialist-resume__quote-image {
        width: 32px;
        height: 24px;
        object-fit: contain;
        vertical-align: top;
        margin-right: var(--spacing-xs);
        display: none;
    }

    .specialist-resume__quote-image--desktop {
        width: 48px;
        height: 48px;
        object-fit: contain;
        margin-bottom: var(--spacing-md);
        display: block;
    }

    .specialist-resume__text {
        margin-bottom: var(--spacing-xl);
        text-shadow: var(--text-shadow-sm);
    }

    .specialist-resume__profile {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
    }

    .specialist-resume__photo {
        width: var(--spacing-7xl);
        height: var(--spacing-7xl);
        border-radius: var(--radius-lg);
        object-fit: cover;
    }

    .specialist-resume__name {
        color: var(--color-text-blue);
    }

    .specialist-resume__title-text {
        color: var(--color-text-blue);
        margin: 0;
    }

    .specialist-resume__points-info {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: var(--spacing-md);
        flex-wrap: wrap;
    }

    .specialist-resume__points-image {
        width: 140px;
        height: auto;
        max-width: 100%;
    }

    .specialist-resume__points-list {
        padding: 0;
        margin: 0;
    }

    .specialist-resume__points-items {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .specialist-resume__point-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-sm);
    }

    .specialist-resume__point-icon {
        background-color: #00FF00;
        color: var(--color-text-white);
        width: var(--spacing-xl);
        height: var(--spacing-xl);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: var(--spacing-md);
        flex-shrink: 0;
    }

    .specialist-resume__point-text {
        line-height: var(--line-height-normal);
    }

