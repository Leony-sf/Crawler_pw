        align-items: center;
        justify-content: center;
        font: 700 14px/var(--line-height-tight) system-ui, sans-serif;
        color: var(--color-text-white);
        padding: 0 var(--spacing-lg);
        border-radius: var(--radius-md) var(--radius-md) 0 0;
    }

    .product-tier__arrow-bottom {
        flex: 1;
        opacity: 0.7;
        border-radius: 0 0 var(--radius-md) var(--radius-md);
    }

    .product-tier__arrow--basic {
        background: linear-gradient(to bottom, #ff6666 30%, #aa0000);
    }

    .product-tier__arrow--basic .product-tier__arrow-top {
        background: #dd140a;
    }

    .product-tier__arrow--basic .product-tier__arrow-bottom {
        background: #b11008;
    }

