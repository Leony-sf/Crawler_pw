    <!-- Carrossel Footer -->
    <script src="jquery.min.js"></script>
    <script src="owl.carousel.js"></script>
    <script>
        $(document).ready(function () {
            var syncing = false;

            var sync1 = $("#carosselfooter");
            var sync2 = $("#carosselfooter2");
            var sync3 = $("#carosselfooter3");
            var sync4 = $("#carosselfooter4");
            var sync5 = $("#carosselfooter5");
            var sync6 = $("#carosselfooter6");

            // Configuração padrão dos carrosséis
            function initCarousel(sync) {
                sync.owlCarousel({
                    loop: false,
                    margin: 10,
                    responsiveClass: true,
                    responsive: {
                        0: { items: 2, nav: false },
                        600: { items: 4, nav: false },
                        1000: { items: 4, nav: false, loop: false }
                    }
                }).on('changed.owl.carousel', syncCarousels);
            }

            // Inicializa todos os carrosséis
            [sync1, sync2, sync3, sync4, sync5, sync6].forEach(initCarousel);

            function syncCarousels(event) {
                if (syncing) return;
                syncing = true;

                var index = event.item.index;
                var sourceId = event.target.id;

                // Lista todos os carrosséis
                var allCarousels = [sync1, sync2, sync3, sync4, sync5, sync6];

                // Move todos, exceto o que disparou o evento
                allCarousels.forEach(function (carousel) {
                    if (carousel.attr('id') !== sourceId) {
                        carousel.trigger('to.owl.carousel', [index, 300, true]);
                    }
                });

                syncing = false;
            }
        });
    </script>


