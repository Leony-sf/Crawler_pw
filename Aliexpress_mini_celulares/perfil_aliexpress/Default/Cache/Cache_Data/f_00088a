    <div class="specialist-resume__content">
      <div class="specialist-resume__summary">
        <p class="specialist-resume__summary-title title">Resumo do especialista</p>
        <div class="specialist-resume__quote">
          <img src="images/aspas.png" alt="Símbolo de citação" class="specialist-resume__quote-image--desktop"
