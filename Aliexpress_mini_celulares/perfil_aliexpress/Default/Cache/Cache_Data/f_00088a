  <script>
    // Dados do produto
    const produto = {
      // Seção de vídeo
      video: {
        tituloVideo: "Super Análise - Comparativo de Smartphones"
      },

      // Resumo do especialista
      especialista: {
        citacao: "Ele conta com as mesmas funções de IA do Galaxy S25 Ultra. Então, é uma boa opção para quem quer todos os recursos inteligentes, mas não quer pagar o valor do modelo mais avançado.",
        perfil: {
          nome: "Bruno Bertozin",
          cargo: "Analista de produtos no Canaltech",
          textoAlternativoFoto: "Foto do especialista Bruno Bertozin, analista de produtos no Canaltech"
        },
        pontosPositivos: {
          pontos: [
            "Design compacto",
            "Excelente desempenho",
            "Bom conjunto de câmeras",
          ]
        }
      },

      // Categorias de produto
      categoriasProduto: {
        nivelSelecionado: {
          nome: "Topo de linha",
          descricao: "O aparelho representa o que há de mais avançado em tecnologia móvel, oferecendo recursos premium, design sofisticado e desempenho excepcional para usuários que exigem o melhor.",
        },
        textoAlternativoImagem: "Imagem do produto"
      },

      // Comparação de produtos
      comparacao: {
        produtoAnterior: {
          nome: "Samsung Galaxy S24",
          link: "#",
          caracteristicas: [
            "Exynos 2400",
            "8 GB de RAM",
            "Android 14 com 7 anos de atualizações ",
            "Câmera de 50 MP "
          ]
        },
        produtoAtual: {
          nome: "Samsung Galaxy S25",
          link: "#",
          caracteristicas: [
            "Snapdragon 8 Elite",
            "12 GB de RAM",
            "Android 15 com 7 anos de atualizações ",
            "Câmera de 50 MP com recurso Best Face"
          ]
        },
        mudancas: {
          itens: [
            "Processador mais rápido, eficiente e estável.",
            "+4 GB de RAM",
            "Android atualizado",
            "Ganhou recurso Best Face"
          ]
        }
      },

      // Raio-X do produto
      raioXProduto: {
        caracteristicas: [
          {
            texto: "Android + OneUI"
          },
          {
            texto: "Gravação em 8K"
          },
          {
            texto: "Câmera principal de 50 MP com IA"
          },
          {
            texto: "Tela AMOLED compacta de 6,2 polegadas"
          }
        ],
        especificacoes: [
          {
            titulo: "Processador",
            valor: "Snapdragon 8 Elite / 2025",
            nivel: "very-high"
          },
          {
            titulo: "Memória RAM",
            valor: "Entre 8GB e 12GB",
            nivel: "high"
          },
          {
            titulo: "Armazenamento",
            valor: "Acima de 128GB",
            nivel: "high"
          },
          {
            titulo: "Garantia de Updates",
            valor: "Acima de 5 anos de updates garantidos",
            nivel: "very-high"
          }
        ],
        niveisEscala: [
          { nome: "Baixo", nivel: "low" },
          { nome: "Médio", nivel: "medium" },
          { nome: "Alto", nivel: "high" },
          { nome: "Muito Alto", nivel: "very-high" }
        ]
      },

      // Seção de prêmio
      premio: {
        descricao: "Este produto foi reconhecido como o Melhor da Categoria no prestigiado Prêmio Canaltech, a maior referência do mercado brasileiro para tecnologia. A premiação é baseada em milhões de votos de consumidores e na análise criteriosa de um painel de especialistas, composto por jornalistas, influenciadores e profissionais do setor. Conheça todos os vencedores em:",
        link: "https://premio.canaltech.com.br",
        textoLink: "premio.canaltech.com.br"
      },
    };

    // Função para preencher dinamicamente o conteúdo
    function preencherConteudo() {
      
      // Preencher resumo do especialista
      preencherEspecialista();
      
      // Preencher categorias de produto
      preencherCategoriasProduto();
      
      // Preencher comparação
      preencherComparacao();
      
      // Preencher raio-X do produto
      preencherRaioXProduto();
      
      // Preencher seção de prêmio
      preencherPremio();
    }


    // Função para preencher resumo do especialista
    function preencherEspecialista() {
      // Citação
      const citacaoElement = document.querySelector('.specialist-resume__text');
      if (citacaoElement) {
        citacaoElement.textContent = produto.especialista.citacao;
      }

      // Nome do especialista
      const nomeElement = document.querySelector('.specialist-resume__name');
      if (nomeElement) {
        nomeElement.textContent = produto.especialista.perfil.nome;
      }

      // Cargo do especialista
      const cargoElement = document.querySelector('.specialist-resume__title-text');
      if (cargoElement) {
        cargoElement.textContent = produto.especialista.perfil.cargo;
      }

      // Texto alternativo da foto
      const fotoElement = document.querySelector('.specialist-resume__photo');
      if (fotoElement) {
        fotoElement.alt = produto.especialista.perfil.textoAlternativoFoto;
      }

      // Pontos positivos
      const pontosLista = document.querySelector('.specialist-resume__points-items');
      if (pontosLista) {
        pontosLista.innerHTML = '';
        produto.especialista.pontosPositivos.pontos.forEach(ponto => {
          const li = document.createElement('li');
          li.className = 'specialist-resume__point-item';
          li.innerHTML = `
            <span class="specialist-resume__point-icon">+</span>
            <span class="specialist-resume__point-text text-normal">${ponto}</span>
          `;
          pontosLista.appendChild(li);
        });
      }
    }

    // Função para preencher categorias de produto
    function preencherCategoriasProduto() {
      // Nome do nível selecionado (mobile)
      const nivelMobile = document.querySelector('.product-tier__level');
      if (nivelMobile) {
        nivelMobile.textContent = produto.categoriasProduto.nivelSelecionado.nome;
      }

      // Descrição (mobile)
      const descricaoMobile = document.querySelector('.product-tier__description');
      if (descricaoMobile) {
        descricaoMobile.textContent = produto.categoriasProduto.nivelSelecionado.descricao;
      }

      // Nome do nível selecionado (tablet)
      const nivelTablet = document.querySelector('.product-tier-tablet__level');
      if (nivelTablet) {
        nivelTablet.textContent = produto.categoriasProduto.nivelSelecionado.nome;
      }

      // Descrição (tablet)
      const descricaoTablet = document.querySelector('.product-tier-tablet__description');
      if (descricaoTablet) {
        descricaoTablet.textContent = produto.categoriasProduto.nivelSelecionado.descricao;
      }

      // Nome do nível selecionado (desktop)
      const nivelDesktop = document.querySelector('.product-tier-desktop__level');
      if (nivelDesktop) {
        nivelDesktop.textContent = produto.categoriasProduto.nivelSelecionado.nome;
      }

      // Descrição (desktop)
      const descricaoDesktop = document.querySelector('.product-tier-desktop__description');
      if (descricaoDesktop) {
        descricaoDesktop.textContent = produto.categoriasProduto.nivelSelecionado.descricao;
      }

      // Texto alternativo das imagens do produto
      const imagensProduto = document.querySelectorAll('.product-image__img, .product-tier-desktop__img');
      imagensProduto.forEach(img => {
        img.alt = produto.categoriasProduto.textoAlternativoImagem;
      });
    }

    // Função para preencher comparação
    function preencherComparacao() {
      // Produto anterior
      const nomeAnterior = document.querySelector('.comparison__card--previous .comparison__card-title');
      if (nomeAnterior) {
        nomeAnterior.textContent = produto.comparacao.produtoAnterior.nome;
      }

      const linkAnterior = document.querySelector('.comparison__card--previous .comparison__card-link');
      if (linkAnterior) {
        linkAnterior.href = produto.comparacao.produtoAnterior.link;
      }

      const caracteristicasAnteriores = document.querySelector('.comparison__card--previous .comparison__card-features');
      if (caracteristicasAnteriores) {
        caracteristicasAnteriores.innerHTML = '';
        produto.comparacao.produtoAnterior.caracteristicas.forEach(caracteristica => {
          const li = document.createElement('li');
          li.className = 'comparison__feature-item text-normal';
          li.textContent = caracteristica;
          caracteristicasAnteriores.appendChild(li);
        });
      }

      // Produto atual
      const nomeAtual = document.querySelector('.comparison__card--current .comparison__card-title');
      if (nomeAtual) {
        nomeAtual.textContent = produto.comparacao.produtoAtual.nome;
      }

      const linkAtual = document.querySelector('.comparison__card--current .comparison__card-link');
      if (linkAtual) {
        linkAtual.href = produto.comparacao.produtoAtual.link;
      }

      const caracteristicasAtuais = document.querySelector('.comparison__card--current .comparison__card-features');
      if (caracteristicasAtuais) {
        caracteristicasAtuais.innerHTML = '';
        produto.comparacao.produtoAtual.caracteristicas.forEach(caracteristica => {
          const li = document.createElement('li');
          li.className = 'comparison__feature-item text-normal';
          li.textContent = caracteristica;
          caracteristicasAtuais.appendChild(li);
        });
      }

      // Mudanças
      const mudancasLista = document.querySelector('.comparison__summary-changes');
      if (mudancasLista) {
        mudancasLista.innerHTML = '';
        produto.comparacao.mudancas.itens.forEach(mudanca => {
          const li = document.createElement('li');
          li.className = 'comparison__change-item';
          li.innerHTML = `
            <span class="comparison__change-icon comparison__change-icon--check">
              <svg width="16" height="11" viewBox="0 0 16 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 5.5L5.5 10L15 1" stroke="#00D604" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span class="comparison__change-text text-normal">${mudanca}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" stroke="#2ECEFF" stroke-width="2" />
              <path d="M12 16v-4M12 8h.01" stroke="#2ECEFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          `;
          mudancasLista.appendChild(li);
        });
      }
    }

    // Função para preencher raio-X do produto
    function preencherRaioXProduto() {
      // Características
      const caracteristicasCards = document.querySelectorAll('.product-xray__feature-card');
      if (caracteristicasCards.length >= produto.raioXProduto.caracteristicas.length) {
        produto.raioXProduto.caracteristicas.forEach((caracteristica, index) => {
          const textoElement = caracteristicasCards[index].querySelector('.product-xray__feature-text');
          if (textoElement) {
            textoElement.textContent = caracteristica.texto;
          }
        });
      }

      // Especificações
      const especificacoesCards = document.querySelectorAll('.product-xray__storage-card');
      if (especificacoesCards.length >= produto.raioXProduto.especificacoes.length) {
        produto.raioXProduto.especificacoes.forEach((especificacao, index) => {
          const card = especificacoesCards[index];
          
          // Título
          const tituloElement = card.querySelector('.product-xray__storage-title');
          if (tituloElement) {
            tituloElement.textContent = especificacao.titulo;
          }

          // Valor
          const valorElement = card.querySelector('.product-xray__storage-value');
          if (valorElement) {
            valorElement.textContent = especificacao.valor;
          }

          // Atualizar escala baseada no nível
          atualizarEscala(card, especificacao.nivel);
        });
      }
    }

    // Função para atualizar escala de especificação
    function atualizarEscala(card, nivel) {
      // Remover classes ativas
      const barras = card.querySelectorAll('.product-xray__scale-bar');
      const setas = card.querySelectorAll('.product-xray__scale-arrow');
      const textos = card.querySelectorAll('.product-xray__scale-text');

      barras.forEach(barra => barra.classList.remove('product-xray__scale-bar--active'));
      setas.forEach(seta => seta.classList.remove('product-xray__scale-arrow--active'));
      textos.forEach(texto => texto.classList.remove('product-xray__scale-text--active'));

      // Adicionar classe ativa baseada no nível
      const nivelIndex = produto.raioXProduto.niveisEscala.findIndex(n => n.nivel === nivel);
      if (nivelIndex !== -1) {
        barras[nivelIndex].classList.add('product-xray__scale-bar--active');
        setas[nivelIndex].classList.add('product-xray__scale-arrow--active');
        textos[nivelIndex].classList.add('product-xray__scale-text--active');
      }
    }

    // Função para preencher seção de prêmio
    function preencherPremio() {
      const descricaoElement = document.querySelector('.award-section__description');
      if (descricaoElement) {
        descricaoElement.innerHTML = `
          ${produto.premio.descricao} <a href="${produto.premio.link}" target="_blank" class="award-section__link">${produto.premio.textoLink}</a>
        `;
      }
    }

    // Executar quando a página carregar
    document.addEventListener('DOMContentLoaded', preencherConteudo);
  </script>
