        </div>
        <div class="specialist-resume__profile">
          <img src="images/photo-perfil.png" alt="Foto do especialista Léo Müller, analista de produtos no Canaltech"
            class="specialist-resume__photo" loading="lazy">
          <div class="expert-info">
            <h3 class="specialist-resume__name title"></h3>
            <p class="specialist-resume__title-text text-normal"></p>
          </div>
        </div>
      </div>

      <!-- Pontos Positivos -->
      <div class="specialist-resume__points">
        <div class="specialist-resume__points-info">
          <img src="images/positive-points.png" alt="Ícone ilustrativo representando pontos positivos do produto"
            class="specialist-resume__points-image" loading="lazy">
          <div class="specialist-resume__points-list">
            <p class="specialist-resume__points-title title">Pontos positivos</p>
            <ul class="specialist-resume__points-items">
              <li class="specialist-resume__point-item">
                <span class="specialist-resume__point-icon">+</span>
                <span class="specialist-resume__point-text text-normal"></span>
              </li>
              <li class="specialist-resume__point-item">
                <span class="specialist-resume__point-icon">+</span>
                <span class="specialist-resume__point-text text-normal"></span>
              </li>
              <li class="specialist-resume__point-item">
                <span class="specialist-resume__point-icon">+</span>
                <span class="specialist-resume__point-text text-normal"></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
