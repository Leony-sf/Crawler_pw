    </div>

    <!-- Vídeo -->
    <div class="video-section__container">
      <div class="video-section__wrapper">
		  <video controls playsinline width="100%" style="height:auto;">
        <source src="./video/PDP 17_Galaxy S25 - HORIZONTAL_v2.mp4" width="100%" frameborder="0" allowfullscreen>
		  </video>
			  </div>
    </div>
  </section>

