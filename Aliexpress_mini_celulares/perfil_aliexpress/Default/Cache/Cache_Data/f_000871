<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galaxy S25 FE</title>

    <link rel="stylesheet" href="owl.carousel.min.css">
    <link rel="stylesheet" href="owl.theme.default.min.css">
    <link rel="stylesheet" href="modal-video.min.css">


    <style>
        /* Geral */
        * {
            margin: 0;
            padding: 0;
        }

        .owl-nav {
            display: none !important;
        }

        body {
            max-width: 1440px !important;
            margin: 0 auto !important;
        }

        .alinhar-imagem {
            width: 100% !important;
        }

        /* Espaços */

        .blank-space-20 {
            height: 20px;
        }

        .blank-space-50 {
            height: 50px;
        }

        .blank-space-75 {
            height: 75px;
        }

        .blank-space-100 {
            height: 200px;
        }

        .blank-space-150 {
            height: 150px;
        }

        .blank-space-200 {
            height: 200px;
        }

        .only-desktop {
            display: block;
        }

        .only-tablet {
            display: none;
        }

        .only-mobile {
            display: none;
        }

        .only-mobile2 {
            display: none;
        }



        /* Fontes */

        @font-face {
            font-family: 'SamsungSharpSans';
            src: url('./fonts/SamsungSharpSans-Bold.ttf');
        }

        @font-face {
            font-family: 'SamsungSharpSans-Regular';
            src: url('./fonts/SamsungSharpSans-Regular.ttf');
        }

        @font-face {
            font-family: 'SamsungSharpSan-Medium';
            src: url('./fonts/SamsungSharpSans-Medium.ttf');
        }

        @font-face {
            font-family: 'SamsungSharpSan-Bold';
            src: url('./fonts/SamsungSharpSans-Bold.ttf');
        }

        @font-face {
            font-family: 'SamsungOne300C';
            src: url('./fonts/SamsungOne-300C_v1.0.ttf');
        }

        @font-face {
            font-family: 'SamsungOne-400';
            src: url('./fonts/SamsungOne-400.ttf');
        }

        @font-face {
            font-family: 'SamsungOne-600';
            src: url('./fonts/SamsungOne-600.ttf');
        }

        @font-face {
            font-family: 'SamsungOne-700';
            src: url('./fonts/SamsungOne-700.ttf');
        }

        /* Textos */

        h1,
        h2,
        h3,
        h4 {
            font-family: 'SamsungSharpSans';
        }

        h5,
        h6,
        p {
            font-family: 'SamsungOne300C';
        }

        p {
            font-size: 1.5em
        }

        h1 {
            font-size: 2.8125em
        }

        h3 {
            font-size: 2em
        }

        h5 {
            font-size: 1em;
        }

        h6 {
            font-size: .9em;
            font-weight: 400;
        }

        .textalign-center {
            text-align: center;
        }

        .uppercase {
            text-transform: uppercase;
        }

        /*Botões*/

        .button {
            background-color: #ffffff;
            color: #000000;
            border: 1px solid #000000;
            padding: 10px 24px 11px 24px;
            border-radius: 25px;
            width: 190px;
            text-align: center;
            font-family: 'SamsungOne300C';
            margin: 0 auto;
        }

        .button:hover {
            color: #000000;
            background-color: #f5f5f5;
        }

        .regulation-text-center {
            margin: 0 10% 0;
        }

        a {
            text-decoration: none;
        }

        /* icones*/

        .icon-title {
            max-width: 100%;
        }



        /*Video*/

        .videomob {
            display: block;
            width: 90%;
            max-width: 900px;
            height: auto;
            border-radius: 16px;
            margin: 0 auto;
        }




        /* Color */
        .backgroundcolor-white {
            background-color: #ffffff;
        }

        .backgroundcolor-black {
            background-color: #000000;
        }

        .backgroundcolor-gray {
            background-color: #f8f8f8;
        }

        .backgroundcolor-gray-2 {
            background-color: #f4f4f4;
        }

        .color-white {
            color: #ffffff;
        }

        .color-black {
            color: #000000;
        }

        .color-red {
            color: #ff0000;
        }

        .color-gray {
            color: #999999;
        }

        .color-blue {
            color: #02a6fe;
            text-transform: uppercase;
            margin-top: 4px
        }

        .tab-bar {
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #333;
            padding: 10px 20px;
            gap: 100px;
            /* Adiciona espaço de 20px entre os itens */
        }


        .tab-bar h5 {
            font-size: 0.8em;
        }

        .tab {
            color: #fff;
            cursor: pointer;
            padding: 0px 10px;
            position: relative;
            text-align: center;
        }

        .tab.active {
            font-weight: bold;
        }

        .tab.active::after {
            content: "";
            position: absolute;
            width: 100%;
            height: 2px;
            background-color: #fff;
            left: 0;
            /* início do conteúdo */
            bottom: -5px;
        }


        /* Remove as bolinhas */
        .owl-dots {
            display: none;
        }

        /* Estilo para as setas de navegação */
        .owl-nav {
            position: absolute;
            top: 50%;
            width: 100%;
            display: flex;
            justify-content: space-between;
            transform: translateY(-50%);
        }


        /* Seletor mais específico para garantir que o fundo seja removido */
        .owl-nav button.owl-prev,
        .owl-nav button.owl-next {
            background: none !important;
            /* Remove qualquer fundo */
            color: #666666;
            border: none !important;
            /* Remove bordas */
            box-shadow: none !important;
            /* Remove sombra */
            cursor: pointer;
            padding: 5px;
            font-size: 70px;
            line-height: 1;
        }

        /* Remove fundo ao passar o mouse */
        .owl-nav button.owl-prev:hover,
        .owl-nav button.owl-next:hover {
            background: none !important;
            /* Garante que não haja fundo ao passar o mouse */
        }

        /* Estilo para as setas de navegação do primeiro carrossel (deixa como está) */
        #carousel3 .owl-nav button.owl-prev,
        #carousel3 .owl-nav button.owl-next {
            color: #ffffff;
            /* Cor padrão das setas */
        }

        /* Estilo para as setas dos outros três carrosséis (brancas) */
        #carousel2 .owl-nav button.owl-prev,
        #carousel2 .owl-nav button.owl-next,
        #carousel1 .owl-nav button.owl-prev,
        #carousel1 .owl-nav button.owl-next,
        #carousel4 .owl-nav button.owl-prev,
        #carousel4 .owl-nav button.owl-next {
            color: #666666 !important;
            /* Define a cor branca para as setas */
        }


        /*Fim CSS Carroseis*/

        /* Parte header */
        .divtext-div-header h1 {
            margin: 15px auto 25px;
        }

        .divimg-div-header img {
            width: 100%;
        }

        .div-div-header .regulation-text-center {
            margin-top: 45px;
        }

        .div-title-image-div-header {
            background-color: #f4f4f4;
            display: flex;
            flex-flow: row nowrap;
            justify-content: center;
            padding-top: 50px;
        }

        /* Parte textleft-imageright */
        .div-textleft-imageright {
            display: flex;
            flex-flow: row nowrap;
            justify-content: center;
            align-items: center;
            max-width: 90%;
            margin: 0 auto;
        }


        .div-textleft-imageright-column-image,
        .div-textleft-imageright-column-text {
            width: 50%;
        }

        .div-textleft-imageright .divtext-textleft-imageright {
            display: flex;
            flex-flow: column nowrap;
            justify-content: start;
            margin: 0 5% 0 10%;
            align-items: start;
        }

        .div-textleft-imageright .divtext-textleft-imageright p {
            margin: 25px 0 25px;
        }

        .divimg-textleft-imageright img {
            width: 100%;
        }

        .displayflex-textleft-imageright {
            border-radius: 50px;
            width: 100%;
            margin-left: auto;
            margin-right: auto;
        }

        /* Parte textcenter-imagecenter */

        .divtext-textcenter-imagecenter {
            max-width: 90%;
            margin: 0 auto;
        }

        .divtext-textcenter-imagecenter p {
            margin: 25px auto;
        }

        .divimg-textcenter-imagecenter img {
            width: 90%;
        }

        .div-textcenter-imagecenter .regulation-text-center {
            margin-top: 45px;
        }

        /* imageleft-textright*/
        .div-imageleft-textright {
            display: flex;
            flex-flow: row nowrap;
            justify-content: center;
            align-items: center;
            max-width: 1300px;
            margin: 0 auto;
        }

        .div-imageleft-textright-column-image,
        .div-imageleft-textright-column-text {
            width: 50%;
        }

        .div-imageleft-textright .divtext-imageleft-textright {
            display: flex;
            flex-flow: column nowrap;
            justify-content: start;
            margin: 0 10% 0 15%;
            align-items: start;

        }

        .div-imageleft-textright .divtext-imageleft-textright p {
            margin: 25px 0 25px;
        }

        .divimg-imageleft-textright img {
            width: 100%;
        }


        /* Parte text-right-imagebackground */
        .divtext-text-right-image-background {
            width: 50%;
            text-align: right;
            margin-left: auto;
            padding-right: 50px;
            /* Ajuste o valor conforme necessário */
        }

        .divtext-text-right-image-background p {
            margin: 50px 0 0 auto;
            /* Garante que o parágrafo também fique à direita */

        }

        .divimg-text-right-image-background img {
            position: relative;
            width: 100%;
            margin-top: 0rem;
        }

        .div-text-right-image-background .regulation-text {
            margin-top: 50px;
            width: 100%;
            text-align: center;
        }

        .div-textright-imagebackground {
            display: flex;
            flex-flow: row nowrap;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        /* Impede que a imagem ultrapasse a div */

        /* Parte text-left-imagebackground */
        .div-textleft-imagebackground {
            position: relative;
            width: 100%;
            display: flex;
            justify-content: center;
        }

        .divimg-text-left-image-background {
            position: relative;
            /* referência para o texto absoluto */
        }

        .divimg-text-left-image-background img {
            width: 100%;
            display: block;
        }

        .texto-sobre-imagem {
            position: absolute;
            top: 50%;
            left: 0;
            transform: translateY(-50%);
            width: auto;
            max-width: 500px;
            /* ou deixe sem isso se não quiser limite */
        }

        .texto-sobre-imagem p {
            padding-top: 10px;
        }

        .divtext-textleft-imageright {
            display: flex;
            flex-flow: column nowrap;
            justify-content: start;
            margin: 0 5% 0 10%;
            align-items: start;
        }


        /*Carrosel Highlists*/


        .Highlight-carrossel {
            width: 100% !important;
            max-width: 900px;
            margin: 0 auto;
            padding-bottom: 20px;
        }

        .title-carrossel-highlights {
            margin: 5% 0 3% 2%;
        }

        .subtitle-highlights {
            font-size: 1.5em !important;
            margin-bottom: 10px;
            margin-left: 2%;
            margin-right: auto;
            text-align: left;
        }

        /*Opção trocar imagem E vídeo*/

        .botoes-design {
            display: flex;
            justify-content: center;
            margin: 10px auto;
            padding: 0 20px;
            /* Reduz o padding lateral */
            gap: 20px;
            max-width: 100%;
            /* Garante que o contêiner não ultrapasse a largura disponível */
            box-sizing: border-box;
            /* Inclui padding e borda na largura total */
        }

        .botoes-design-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            width: 30%;
            /* Largura proporcional */
            min-width: 120px;
            /* Largura mínima para evitar que fiquem muito pequenos */
            box-sizing: border-box;
            /* Inclui padding e borda na largura total */
        }

        .botoes-design-item button {
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            width: 100%;
            /* Ocupa toda a largura do contêiner */
        }

        .botoes-design-item img {
            width: 100%;
            /* A imagem ocupa toda a largura do botão */
            max-width: 80px;
            /* Tamanho máximo para manter o padrão */
            height: auto;
            transition: transform 0.3s ease;
        }

        .botoes-design-item button:hover img {
            transform: scale(1.1);
            /* Efeito ao passar o mouse */
        }

        .botoes-design h2,
        .botoes-design p {
            color: white;
            margin: 5px 0;
            /* Espaçamento uniforme */
            text-align: center;
        }

        .botoes-design h2 {
            font-size: 1.2rem;
        }

        .botoes-design p {
            font-size: 0.8rem;
        }

        /*Carrossel Expêriencia Galaxy*/

        .displayflex-experience-galaxy {
            display: flex;
            flex-flow: row nowrap;
            justify-content: space-around;
            margin-top: 80px;
            margin-bottom: 65px;
        }

        .div-experience-galaxy img {
            width: 100%;
            margin-bottom: 45px;
        }

        .divtext-experience-galaxy {
            margin-left: 25px;
            margin-right: 50px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 220px;
        }

        .divtext-experience-galaxy h3 {
            margin-top: 0;
            margin-bottom: 25px;

        }

        .divtext-experience-galaxy p {
            flex-grow: 1;
        }

        .div-experience-galaxy-button {
            margin: 0 auto !important;
        }

        .button {
            margin-top: auto;
        }

        .item-experience-galaxy {
            min-width: 33%;
            padding: 10px 0;
            background-color: #ffffff;
            margin: 0px 10px;
            border-radius: 15px;
        }

        /*Carrosel Footer*/

        .icon-galaxy-Ai {
            width: 20px;
            height: 20px;
        }

        .owl-carousel {
            margin: 0 !important;
        }


        .color-line-compare {
            background-color: #f0f2f1;
        }

        .subtitle-carrossel {
            margin: 0 0 0 5%;
        }

        .title-compare {
            font-family: SamsungSharpSan-Medium;
            font-size: 2.5em;
            text-align: center;
        }

        #carosselfooter .item hr {
            border: none;
            border-top: 1px solid #f0f0f0;
        }

        .smart-title {
            font-family: SamsungSharpSan-Bold;
            font-size: 1.1em !important;
            margin-bottom: 20px;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
            font-weight: bold;

        }

        .smart-subtitle {
            font-family: SamsungOne-700;
            font-size: 1em !important;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }

        .smart-subtitle2 {
            font-family: SamsungOne-700;
            font-size: 0.9em !important;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }

        .smart-subtitle2-2 {
            font-family: SamsungOne-700;
            font-size: 0.7em !important;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }

        .smart-subtitle3 {
            font-family: SamsungOne-600;
            font-size: 0.938em !important;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
            font-weight: 700;
        }

        .subtitle-carrossel {
            font-size: 18px !important;
            margin-bottom: 25px;
            margin-left: auto;
            margin-right: auto;
            text-align: center;
        }

        .margin-subtitle {
            padding-bottom: 25px;
        }

        .item {
            min-width: 31%;
            padding: 40px 0px;
            background-color: #ffffff;
            border-radius: 15px;
        }

        .item-img {
            margin-bottom: 10px;
            max-width: 114px;
        }

        .icon-info {
            max-width: 99px;
            margin-left: auto;
            margin-right: auto;
            padding: 0 10%;
        }

        .icon-info2 {
            max-width: 80px;
            margin-left: auto;
            margin-right: auto;
            padding: 10%;
        }

        .item-img {
            max-width: 240px;
            margin-left: auto;
            margin-right: auto;
        }

        .item .item-div {
            padding: 10px 5px !important;
            border-width: 3px;
            height: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;


        }

        .item .item-div>* {
            flex: 1;
            /* faz com que os itens filhos cresçam igualmente */
            min-width: 0;
            /* permite que os itens encolham abaixo do seu tamanho mínimo */
        }

        .item .item-div>.item-filho {
            flex-grow: 1;
            /* permite crescer */
            flex-shrink: 1;
            /* permite encolher */
            flex-basis: auto;
            /* tamanho base automático */
        }

        .item .item-div .spec-title {
            font-size: 40px;
            text-align: center;
        }

        .spec-info {
            font-size: 20px;
            text-align: center;
        }

        .item .item-div .spec-title-2 {
            font-size: 30px;
            text-align: center;
        }

        .item .item-div .spec-title-2.inline {
            display: inline-block;
            text-align: center;
        }

        .item .item-div .spec-sub {
            text-align: center;
            display: inline;
            font-size: 34px;
        }

        .spec-title {
            font-size: 26px;
        }

        /*FAQ*/
        .accordion-section.open .accordion-content {
            flex-direction: column;
            align-items: center;
        }

        .accordion-content img {
            width: 100%;
            margin-bottom: 10px;
        }

        .accordion-content p {
            width: 100%;
        }

        .faq-container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 15px;
            font-family: 'SamsungOne-700';
        }

        .faq-container p {
            font-family: 'SamsungOne300';
            color: #000000;
        }

        .faq-container-title {
            text-align: left;
        }

        .accordion-item {
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            overflow: hidden;
        }

        .accordion-header {
            background-color: transparent;
            color: #000000;
            cursor: pointer;
            padding: 20px 20px 20px 100px;
            font-size: 20px;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .qa-indicator {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            width: 80px;
            height: 40px;
            background-color: #525252;
            color: white;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: bold;
        }

        .answer-indicator {
            position: absolute;
            left: 15px;
            top: 0px;
            width: 80px;
            height: 40px;
            background-color: #f6a424;
            color: white;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: bold;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .accordion-item.active .answer-indicator {
            opacity: 1;
        }

        .accordion-content {
            max-height: 0;
            opacity: 0;
            padding: 0 20px 0 60px;
            overflow: hidden;
            transition: max-height 0.7s ease, opacity 0.5s ease, padding 0.3s ease;
            font-family: 'SamsungOne300C';
            position: relative;
        }

        .accordion-content.open {
            opacity: 1;
            padding: 0px 20px 40px 100px;
            font-family: 'SamsungOne300C';
            color: #000000;
        }

        .icon {
            font-size: 24px;
            transition: transform 0.3s ease;
            color: #525252;
        }

        .accordion-item.active .icon {
            color: #f6a424;
            transform: rotate(180deg);
        }

        .galaxy-ai-img img {
            width: auto;
            height: auto;
            max-width: 80%;
            object-fit: contain;
            margin: 0 auto;
        }


        @media only screen and (min-device-width: 768px) and (max-device-width: 1024px) and (-webkit-min-device-pixel-ratio: 2) {
            .galaxy-ai-img img {
                width: 50% !important;
                height: auto !important;
                margin: 0 auto;
                object-fit: contain;
            }


        }

        @media (max-width: 1000px) and (min-width: 641px) {

            .divtext-text-left-image-background {
                width: 100%;
                padding: 0 10%;
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                /* ou center se quiser centralizar tudo */
            }

            .divtext-text-left-image-background p {
                max-width: 50vw;
                width: 100%;
                /* Para garantir que ele não ultrapasse */
                text-align: left;
            }

            .texto-sobre-imagem {
                width: 50%;
            }

        }


        /* Estilos para telas menores que 640px (mobile) */
        @media (max-width: 640px) {


            .div-textleft-imagebackground p {
                padding: 5% 10%;
            }

            .div-textleft-imagebackground h1 {
                padding-top: 50px;
                display: block;
                text-align: center !important;
                margin: 0 auto;
            }

            .texto-sobre-imagem {
                position: absolute;
                top: 0;
                transform: none;
                z-index: 2;
                text-align: center;
                margin: 0 5%;
            }

            .divimg-text-left-image-background {
                position: relative;
                display: block;
            }

            .divimg-text-left-image-background img {
                width: 100%;
                height: auto;
                display: block;
            }

            .divtext-text-left-image-background {
                width: 90%;
                text-align: center;
                margin: 0 auto;
                padding-left: 0;
            }

            .divtext-text-left-image-background p {
                margin: 30px auto;
            }

            .div-textleft-imagebackground p {
                padding: 5% 10%;
            }




            /* Parte text-right-imagebackground */
            .divtext-text-right-image-background {
                width: 90%;
                text-align: center;
                margin: 0 auto;
                padding-right: 0px;
            }

            .divtext-text-right-image-background p {
                margin: 50px auto;
            }

            .div-text-right-image-background .regulation-text {
                width: 90%;
                text-align: center;
                margin: 50px auto 0;
                text-align: center;
