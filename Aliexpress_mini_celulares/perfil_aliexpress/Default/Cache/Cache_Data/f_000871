    <script>
        $(document).ready(function () {
            // Configuração comum para todos os carrosséis
            const carouselOptions = {
                items: 1,
                loop: false,
                nav: true,
                dots: false,
                navText: ['<div class="nav-prev">‹</div>', '<div class="nav-next">›</div>'],
                onInitialized: updateNavButtons,
                onChanged: updateNavButtons
            };

            // Inicializa os carrosséis
            $("#carousel1-bloco").owlCarousel(carouselOptions);
            $("#carousel2-bloco").owlCarousel(carouselOptions);
            $("#carousel3-bloco").owlCarousel(carouselOptions);
            $("#carousel4-bloco").owlCarousel(carouselOptions);
            $("#carousel5-bloco").owlCarousel(carouselOptions);
            $("#carousel6-bloco").owlCarousel(carouselOptions);

            // Função para desativar setas quando não houver mais itens
            function updateNavButtons(event) {
                const carousel = event.target;
                const items = event.item.count;
                const current = event.item.index;

                // Encontra os botões de navegação deste carrossel
                const $prev = $(carousel).find('.owl-prev');
                const $next = $(carousel).find('.owl-next');

                // Desativa seta anterior se estiver no primeiro item
                $prev.toggleClass('disabled', current === 0);

                // Desativa próxima seta se estiver no último item
                $next.toggleClass('disabled', current >= items - 1);
            }

            // Função para ativar abas e carrossel
            function activateTabAndCarousel(tabBarId, carouselId) {
                $(tabBarId + ' .tab').click(function () {
                    var index = $(this).data('index');
                    $(tabBarId + ' .tab').removeClass('active');
                    $(this).addClass('active');
                    $(carouselId).trigger('to.owl.carousel', [index, 300]);
                });

                $(carouselId).on('changed.owl.carousel', function (event) {
                    var currentItem = event.item.index;
                    $(tabBarId + ' .tab').removeClass('active');
                    $(tabBarId + ' .tab[data-index="' + currentItem + '"]').addClass('active');
                });
            }

            // Ativa abas e carrossel para cada conjunto
            activateTabAndCarousel('#tab-bar1', '#carousel1-bloco');
            activateTabAndCarousel('#tab-bar2', '#carousel2-bloco');
            activateTabAndCarousel('#tab-bar3', '#carousel3-bloco');
            activateTabAndCarousel('#tab-bar4', '#carousel4-bloco');
            activateTabAndCarousel('#tab-bar5', '#carousel5-bloco');
            activateTabAndCarousel('#tab-bar6', '#carousel6-bloco');
        });
    </script>
